import tkinter
from tkinter import messagebox

class My_GUI:

   def __init__(self):
       self.main_window = tkinter.Tk()
       self.main_window.title('address GUI')

       self.my_button = tkinter.Button(self.main_window, text = 'show address', command = self.show_address)
       self.my_button.pack()
       self.quit_button = tkinter.Button(self.main_window, text = 'Quit', command = self.main_window.destroy)
       self.quit_button.pack()

       tkinter.mainloop()

   def show_address(self):
        tkinter.messagebox.showinfo('address', 'Josiah Bliss \n 1234 cool rd N, awsome city, texas')

if __name__ == '__main__':
    gui = My_GUI()
